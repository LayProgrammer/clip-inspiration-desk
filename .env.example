# local = no cloud AI, only heuristic fallback.
# Other providers use your own API key from this local machine.
# Supported: local, zhipu, openai, deepseek, qwen, moonshot, doubao, custom.
AI_PROVIDER=local

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.1-mini
OPENAI_VISION_MODEL=gpt-5.1-mini

ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_MODEL=glm-4-flash
ZHIPU_VISION_MODEL=glm-4v-flash

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_VISION_MODEL=

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_VISION_MODEL=qwen-vl-max

MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-8k
MOONSHOT_VISION_MODEL=

DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-1-5-pro-32k-250115
DOUBAO_VISION_MODEL=doubao-1-5-vision-pro-32k-250115

CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL=
CUSTOM_VISION_MODEL=
